/*
 * CONFIGURATION HEADER FOR RASPBERRY PI PICO BOARD
 * USED AS INFRARED TRANSMITTER EMULATOR FOR
 * HEWLETT-PACKARD 82240B THERMAL PRINTER
*/

/* Infrared transceiver emulation configuration */
#define IR_TRANSMITTER_PIN ${PICO_TRANSMITTER_PIN}

#define SIGNAL_PIN_OFFSET ${PICO_GPIO_PIN_OFFSET}
#define IR_SIGNAL_PIN (IR_TRANSMITTER_PIN - SIGNAL_PIN_OFFSET)

/* Printer hardware definition constants */
#define LINEFEED_DURATION ${LINEFEED_DURATION}
#define CHAR_LINE_WIDTH ${CHAR_LINE_WIDTH}
#define WCHAR_LINE_WIDTH ${WCHAR_LINE_WIDTH}
#define DOT_CHAR_WIDTH ${DOT_CHAR_WIDTH}
#define DOT_CHAR_HEIGHT ${DOT_CHAR_HEIGHT}
#define DOT_LINE_WIDTH ${DOT_LINE_WIDTH}

